
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ROOT COLLECTIONS
    
    // Explicit rules for Top-ups (Root Collection)
    match /user_topups/{id} {
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.query.filters.userId == request.auth.uid)
      );
      allow write: if false; // Only Admin SDK can write
    }

    // Explicit rules for Subscriptions (Root Collection)
    match /user_subscriptions/{id} {
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.query.filters.userId == request.auth.uid)
      );
      allow write: if false; // Only Admin SDK can write
    }

    // Public Voice Profiles
    match /voices/{voiceId} {
      // Enhanced read rule: Allow read if voice is public OR if the user is the owner
      allow read: if (resource.data.isPublic == true || resource.data.status == 'approved') || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Public Documentation
    match /documentation/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // OTP Verification (Internal)
    match /verification_otps/{email} {
      allow read, write: if false; // Only Admin SDK
    }

    // USER-SPECIFIC DATA
    match /users/{userId} {
      // 1. Basic Profile Access (Name, Avatar, ReferralCode)
      // Allow 'get' for everyone to see speaker names/avatars.
      allow get: if isSignedIn();
      
      // 2. Full Document Access (Owner/Admin)
      // Sensitive data like 'apiKey' and 'email' are only readable by owner.
      allow read, write: if isOwner(userId) || isAdmin();
      
      // 3. Referral Code Lookup (Sign-up flow)
      // Allows the specific query used during sign-up to find a referrer by code.
      allow list: if isSignedIn() && 
                    request.query.limit <= 1 && 
                    request.query.filters.referralCode != null;

      // SUBCOLLECTIONS
      
      match /myVoices/{voiceId} {
        allow read, write: if isOwner(userId);
      }

      match /generations/{genId} {
        allow read, write: if isOwner(userId);
      }

      match /api_logs/{logId} {
        allow read: if isOwner(userId);
      }

      match /referrals/{refId} {
        allow read: if isOwner(userId);
        allow write: if isSignedIn(); // Allow recording new referrals during sign-up
      }
    }
  }
}