rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ROOT COLLECTIONS
    
    // Explicit rules for Subscriptions (Root Collection)
    match /user_subscriptions/{id} {
      allow list: if isSignedIn() && (isAdmin() || (request.query.filters != null && request.query.filters.userId == request.auth.uid));
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if false; 
    }

    // Public Voice Profiles
    match /voices/{voiceId} {
      allow read: if (resource.data.isPublic == true) || (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Public Documentation
    match /documentation/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // OTP Verification (Internal)
    match /verification_otps/{email} {
      allow read, write: if false; 
    }

    // USER-SPECIFIC DATA
    match /users/{userId} {
      allow get: if isSignedIn();
      allow read, write: if isOwner(userId) || isAdmin();
      
      allow list: if isSignedIn() && isAdmin();

      // SUBCOLLECTIONS
      
      match /savedVoices/{voiceId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /myVoices/{voiceId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /generations/{genId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /api_logs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
      }
    }
  }
}
