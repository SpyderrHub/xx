
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "plan": { "type": "string" },
        "credits": { "type": "number" },
        "role": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "currentPeriodStart": { "type": "string", "format": "date-time" },
        "currentPeriodEnd": { "type": "string", "format": "date-time" },
        "billingCycle": { "type": "string" },
        "dailyMusicGenerationsCount": { "type": "number" },
        "lastMusicGenerationDate": { "type": "string" },
        "dailyVoiceDesignCount": { "type": "number" },
        "lastVoiceDesignDate": { "type": "string" },
        "lastIp": { "type": "string", "description": "Stored for multi-account detection." },
        "referralCode": { "type": "string", "description": "Unique code for referring others." },
        "referredBy": { "type": "string", "description": "UID of the user who referred this user." },
        "referralCount": { "type": "number", "description": "Total number of successfully verified referrals." },
        "isVerified": { "type": "boolean", "description": "Whether the user's email has been verified via OTP." }
      },
      "required": ["uid", "name", "email", "createdAt", "plan", "credits", "role", "referralCode", "referralCount", "isVerified"]
    },
    "Referral": {
      "title": "Referral",
      "type": "object",
      "properties": {
        "referredUserId": { "type": "string" },
        "referredUserName": { "type": "string" },
        "referredUserEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "rewardClaimed": { "type": "boolean" }
      },
      "required": ["referredUserId", "status", "createdAt"]
    },
    "Voice": {
      "title": "Voice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "voiceName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "description": { "type": "string" },
        "referenceText": { "type": "string" },
        "languages": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "gender": { "type": "string" },
        "style": { "type": "string" },
        "styles": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "audioUrl": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "voiceName", "languages", "gender", "status", "createdAt"]
    },
    "Generation": {
      "title": "Generation",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "fullText": { "type": "string" },
        "voiceId": { "type": "string" },
        "voiceName": { "type": "string" },
        "characters": { "type": "number" },
        "audioUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": { "type": "object" }
      },
      "required": ["text", "fullText", "voiceId", "voiceName", "characters", "audioUrl", "createdAt"]
    },
    "UserSubscription": {
      "title": "UserSubscription",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planType": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planType", "status", "createdAt"]
    },
    "OTP": {
      "title": "OTP",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "code": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "code", "expiresAt"]
    },
    "DocumentationPage": {
      "title": "DocumentationPage",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "order", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and subscription data."
    },
    "/users/{userId}/generations/{genId}": {
      "schema": { "$ref": "#/entities/Generation" },
      "description": "Individual synthesis history records."
    },
    "/users/{userId}/referrals/{refId}": {
      "schema": { "$ref": "#/entities/Referral" },
      "description": "Log of users referred by this user."
    },
    "/user_subscriptions/{id}": {
      "schema": { "$ref": "#/entities/UserSubscription" },
      "description": "Log of user subscription activations."
    },
    "/voices/{voiceId}": {
      "schema": { "$ref": "#/entities/Voice" },
      "description": "Public voice profiles for the library."
    },
    "/documentation/{docId}": {
      "schema": { "$ref": "#/entities/DocumentationPage" },
      "description": "Publicly readable documentation pages."
    },
    "/verification_otps/{email}": {
      "schema": { "$ref": "#/entities/OTP" },
      "description": "Temporary storage for email verification codes."
    }
  }
}
