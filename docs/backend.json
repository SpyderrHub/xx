
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "plan": { "type": "string" },
        "credits": { "type": "number" },
        "role": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "currentPeriodStart": { "type": "string", "format": "date-time" },
        "currentPeriodEnd": { "type": "string", "format": "date-time" },
        "billingCycle": { "type": "string" }
      },
      "required": ["uid", "name", "email", "createdAt", "plan", "credits", "role"]
    },
    "Voice": {
      "title": "Voice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "voiceName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "description": { "type": "string" },
        "referenceText": { "type": "string" },
        "languages": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "gender": { "type": "string" },
        "style": { "type": "string" },
        "styles": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "audioUrl": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "voiceName", "languages", "gender", "status", "createdAt"]
    },
    "DocumentationPage": {
      "title": "DocumentationPage",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "order", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and subscription data."
    },
    "/voices/{voiceId}": {
      "schema": { "$ref": "#/entities/Voice" },
      "description": "Public voice profiles for the library."
    },
    "/documentation/{docId}": {
      "schema": { "$ref": "#/entities/DocumentationPage" },
      "description": "Publicly readable documentation pages."
    }
  }
}
